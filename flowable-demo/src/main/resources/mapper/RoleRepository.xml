<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.flowable.repository.RoleRepository">

    <resultMap id="RoleResultMap" type="Role">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="RoleColumns">id, name, code, description, status, created_at, updated_at</sql>

    <select id="selectById" resultMap="RoleResultMap">
        select <include refid="RoleColumns"/>
        from sys_role
        where id = #{id}
    </select>

    <select id="findByCode" resultMap="RoleResultMap">
        select <include refid="RoleColumns"/>
        from sys_role
        where code = #{code}
    </select>

    <select id="findAll" resultMap="RoleResultMap">
        select <include refid="RoleColumns"/>
        from sys_role
        order by id
    </select>

    <select id="findAllById" resultMap="RoleResultMap">
        select <include refid="RoleColumns"/>
        from sys_role
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        order by id
    </select>

    <insert id="insert" parameterType="Role" useGeneratedKeys="true" keyProperty="id">
        insert into sys_role (name, code, description, status, created_at, updated_at)
        values (#{name}, #{code}, #{description}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="Role">
        update sys_role
        set name = #{name},
            code = #{code},
            description = #{description},
            status = #{status},
            created_at = #{createdAt},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <delete id="removeById">
        delete from sys_role where id = #{id}
    </delete>
</mapper>
