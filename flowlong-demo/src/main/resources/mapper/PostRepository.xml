<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.flowlong.repository.PostRepository">

    <resultMap id="PostResultMap" type="com.example.flowlong.entity.Post">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="departmentId" column="department_id"/>
        <result property="level" column="level"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="PostColumns">id, name, code, department_id, level, status, description, created_at, updated_at</sql>

    <select id="selectById" resultMap="PostResultMap">
        select <include refid="PostColumns"/>
        from sys_post
        where id = #{id}
    </select>

    <select id="findByCode" resultMap="PostResultMap">
        select <include refid="PostColumns"/>
        from sys_post
        where code = #{code}
    </select>

    <select id="findAll" resultMap="PostResultMap">
        select <include refid="PostColumns"/>
        from sys_post
        order by id
    </select>

    <select id="findByStatus" resultMap="PostResultMap">
        select <include refid="PostColumns"/>
        from sys_post
        where status = #{status}
        order by id
    </select>

    <select id="findPageByCondition" resultMap="PostResultMap">
        select <include refid="PostColumns"/>
        from sys_post
        <include refid="PostQueryWhere"/>
        order by id
        limit #{query.safeSize}
        offset #{query.offset}
    </select>

    <select id="countByCondition" resultType="long">
        select count(*)
        from sys_post
        <include refid="PostQueryWhere"/>
    </select>

    <select id="countByDepartmentId" resultType="long">
        select count(*)
        from sys_post
        where department_id = #{departmentId}
    </select>

    <insert id="insert" parameterType="com.example.flowlong.entity.Post" useGeneratedKeys="true" keyProperty="id">
        insert into sys_post (name, code, department_id, level, status, description, created_at, updated_at)
        values (#{name}, #{code}, #{departmentId}, #{level}, #{status}, #{description}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.flowlong.entity.Post">
        update sys_post
        set name = #{name},
            code = #{code},
            department_id = #{departmentId},
            level = #{level},
            status = #{status},
            description = #{description},
            created_at = #{createdAt},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <delete id="removeById">
        delete from sys_post where id = #{id}
    </delete>

    <sql id="PostQueryWhere">
        <where>
            <if test="query != null and query.status != null">
                and status = #{query.status}
            </if>
            <if test="query != null and query.departmentId != null">
                and department_id = #{query.departmentId}
            </if>
            <if test="query != null and query.normalizedKeyword != null">
                and (
                    name ilike concat('%', #{query.normalizedKeyword}, '%')
                    or code ilike concat('%', #{query.normalizedKeyword}, '%')
                    or level ilike concat('%', #{query.normalizedKeyword}, '%')
                    or description ilike concat('%', #{query.normalizedKeyword}, '%')
                )
            </if>
        </where>
    </sql>
</mapper>
