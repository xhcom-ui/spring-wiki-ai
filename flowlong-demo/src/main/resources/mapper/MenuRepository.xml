<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.flowlong.repository.MenuRepository">

    <resultMap id="MenuResultMap" type="com.example.flowlong.entity.Menu">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="path" column="path"/>
        <result property="component" column="component"/>
        <result property="icon" column="icon"/>
        <result property="parentId" column="parent_id"/>
        <result property="sort" column="sort"/>
        <result property="type" column="type"/>
        <result property="permission" column="permission"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="MenuColumns">id, name, path, component, icon, parent_id, sort, type, permission, status, created_at, updated_at</sql>

    <select id="selectById" resultMap="MenuResultMap">
        select <include refid="MenuColumns"/>
        from sys_menu
        where id = #{id}
    </select>

    <select id="findByStatus" resultMap="MenuResultMap">
        select <include refid="MenuColumns"/>
        from sys_menu
        where status = #{status}
        order by sort nulls last, id
    </select>

    <select id="findAll" resultMap="MenuResultMap">
        select <include refid="MenuColumns"/>
        from sys_menu
        order by sort nulls last, id
    </select>

    <select id="findAllById" resultMap="MenuResultMap">
        select <include refid="MenuColumns"/>
        from sys_menu
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        order by sort nulls last, id
    </select>

    <select id="findPageByCondition" resultMap="MenuResultMap">
        select <include refid="MenuColumns"/>
        from sys_menu
        <include refid="MenuQueryWhere"/>
        order by sort nulls last, id
        limit #{query.safeSize}
        offset #{query.offset}
    </select>

    <select id="countByCondition" resultType="long">
        select count(*)
        from sys_menu
        <include refid="MenuQueryWhere"/>
    </select>

    <insert id="insert" parameterType="com.example.flowlong.entity.Menu" useGeneratedKeys="true" keyProperty="id">
        insert into sys_menu (name, path, component, icon, parent_id, sort, type, permission, status, created_at, updated_at)
        values (#{name}, #{path}, #{component}, #{icon}, #{parentId}, #{sort}, #{type}, #{permission}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.flowlong.entity.Menu">
        update sys_menu
        set name = #{name},
            path = #{path},
            component = #{component},
            icon = #{icon},
            parent_id = #{parentId},
            sort = #{sort},
            type = #{type},
            permission = #{permission},
            status = #{status},
            created_at = #{createdAt},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <delete id="removeById">
        delete from sys_menu where id = #{id}
    </delete>

    <sql id="MenuQueryWhere">
        <where>
            <if test="query != null and query.status != null">
                and status = #{query.status}
            </if>
            <if test="query != null and query.normalizedKeyword != null">
                and (
                    name ilike concat('%', #{query.normalizedKeyword}, '%')
                    or path ilike concat('%', #{query.normalizedKeyword}, '%')
                    or permission ilike concat('%', #{query.normalizedKeyword}, '%')
                )
            </if>
        </where>
    </sql>
</mapper>
